{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QTE Time Tracker",
  "version": "0.2.1",
  "identifier": "se.qte.timetracker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QTE Time Tracker",
        "label": "main",
        "width": 450,
        "height": 700,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 500,
        "decorations": true,
        "visible": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.agileday.io"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "qte-tracker"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/Kaijonsson/agileday-tracker/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQ37tcMFx+p3u2kZQc37QqCEqS4KJ0bV4EdrpfPB9ETr82rz6SbH70l"
    }
  }
}
